# LLM 生成（DeepSeek，推荐·新用户约 500 万 token 免费额度）
# 申请：https://platform.deepseek.com/
LLM_API_KEY=your_deepseek_key_here
LLM_BASE_URL=https://api.deepseek.com
# 也可用 deepseek-chat；你当前账号已验证 deepseek-v4-pro 可用
LLM_MODEL=deepseek-v4-pro

# 方案 B（Google Gemini 免费层，有 RPM/RPD 限额）
# LLM_API_KEY=your_google_api_key_here
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
# LLM_MODEL=gemini-2.0-flash

# 方案 C（本地免费）：Ollama
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b

# RAG（推荐 local，完全免费，不消耗 API）
RAG_TOP_K=5
EMBEDDING_BACKEND=local
LOCAL_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
# 国内首次建索引若 HuggingFace 超时：
HF_ENDPOINT=https://hf-mirror.com

# 备选：付费/云端嵌入（一般不需要）
# EMBEDDING_BACKEND=openai
# OPENAI_API_KEY=your_key_here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBED_MODEL=text-embedding-3-small
